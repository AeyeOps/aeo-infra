<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <!-- =================================================================
       PASS 1: windowsPE
       Runs inside WinPE before OS image is applied to disk.
       Handles: HW bypass, disk partitioning, driver injection, image selection.
       ================================================================= -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">

      <!-- Bypass Windows 11 hardware requirements (TPM, SecureBoot, etc.) -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>

      <!-- UEFI/GPT disk layout: EFI (100MB) + MSR (16MB) + Windows (rest) -->
      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>2</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Size>100</Size>
              <Type>EFI</Type>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Size>16</Size>
              <Type>MSR</Type>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Extend>true</Extend>
              <Type>Primary</Type>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>System</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
        <WillShowUI>OnError</WillShowUI>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>Windows 11 Pro</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>2</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
        </OSImage>
      </ImageInstall>

      <UserData>
        <ProductKey>
          <Key>W269N-WFGWX-YVC9B-4J6C9-T83GX</Key>
        </ProductKey>
        <AcceptEula>true</AcceptEula>
      </UserData>
    </component>

    <!-- VirtIO driver injection: vioscsi + viostor + NetKVM for ARM64
         Drive letter varies with USB enumeration order, so cover D: E: F:
         Invalid paths are silently ignored -->
    <component name="Microsoft-Windows-PnpCustomizationsWinPE"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <DriverPaths>
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>D:\vioscsi\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>D:\NetKVM\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="3">
          <Path>E:\vioscsi\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="4">
          <Path>E:\NetKVM\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="5">
          <Path>F:\vioscsi\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="6">
          <Path>F:\NetKVM\w11\ARM64</Path>
        </PathAndCredentials>
      </DriverPaths>
    </component>
  </settings>

  <!-- =================================================================
       PASS 3: specialize
       Runs on first boot of installed OS. Machine-specific config.
       ================================================================= -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <ComputerName>WINVM</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>
  </settings>

  <!-- =================================================================
       PASS 7: oobeSystem
       Runs during Windows Welcome. User accounts, OOBE skip, first-run.
       ================================================================= -->
  <settings pass="oobeSystem">

    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <ProtectYourPC>3</ProtectYourPC>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>testuser</Name>
            <DisplayName>Test User</DisplayName>
            <Group>Administrators</Group>
            <Password>
              <Value>TestPass123!</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>testuser</Username>
        <Password>
          <Value>TestPass123!</Value>
          <PlainText>true</PlainText>
        </Password>
        <LogonCount>1</LogonCount>
      </AutoLogon>

      <FirstLogonCommands>
        <!-- 0. Start logging for post-mortem debugging -->
        <SynchronousCommand wcm:action="add">
          <Order>0</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "Start-Transcript -Path C:\Windows\Temp\firstlogon.log -Append; Write-Host '=== FirstLogonCommands starting ===' ; Write-Host \"Timestamp: $(Get-Date -Format o)\""</CommandLine>
          <Description>Start transcript logging</Description>
        </SynchronousCommand>

        <!-- 1. Enable OpenSSH Server -->
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "Write-Host '=== Step 1: OpenSSH ==='; try { Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0 -ErrorAction Stop; Start-Service sshd -ErrorAction Stop; Set-Service sshd -StartupType Automatic; Write-Host 'OpenSSH: SUCCESS' } catch { Write-Host \"OpenSSH: FAILED - $_\" }"</CommandLine>
          <Description>Install and enable OpenSSH Server</Description>
        </SynchronousCommand>

        <!-- 2. Set static IP (find first active adapter dynamically) -->
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "Write-Host '=== Step 2: Static IP ==='; try { $a = Get-NetAdapter | Where-Object {$_.Status -eq 'Up'} | Select-Object -First 1; if (-not $a) { throw 'No active adapter found' }; New-NetIPAddress -InterfaceIndex $a.ifIndex -IPAddress 192.168.50.200 -PrefixLength 24 -DefaultGateway 192.168.50.1 -ErrorAction Stop; Set-DnsClientServerAddress -InterfaceIndex $a.ifIndex -ServerAddresses 8.8.8.8; Write-Host 'Static IP: SUCCESS' } catch { Write-Host \"Static IP: FAILED - $_\" }"</CommandLine>
          <Description>Set static IP address</Description>
        </SynchronousCommand>

        <!-- 3. Download and install Tailscale (direct MSI, no winget dependency) -->
        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "Write-Host '=== Step 3: Tailscale ==='; try { Invoke-WebRequest -Uri 'https://pkgs.tailscale.com/stable/tailscale-setup-latest-arm64.msi' -OutFile C:\Windows\Temp\tailscale.msi -ErrorAction Stop; Start-Process msiexec.exe -ArgumentList '/i','C:\Windows\Temp\tailscale.msi','/quiet','/norestart' -Wait; Write-Host 'Tailscale: SUCCESS' } catch { Write-Host \"Tailscale: FAILED - $_\" }"</CommandLine>
          <Description>Download and install Tailscale</Description>
        </SynchronousCommand>

        <!-- 98. Stop transcript before shutdown -->
        <SynchronousCommand wcm:action="add">
          <Order>98</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "Write-Host '=== FirstLogonCommands complete ==='; Stop-Transcript"</CommandLine>
          <Description>Stop transcript logging</Description>
        </SynchronousCommand>

        <!-- 99. Signal build complete by shutting down -->
        <SynchronousCommand wcm:action="add">
          <Order>99</Order>
          <CommandLine>shutdown /s /t 30 /c "Base image build complete"</CommandLine>
          <Description>Shut down after setup complete</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>

</unattend>
