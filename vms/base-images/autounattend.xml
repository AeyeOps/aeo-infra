<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <!-- =================================================================
       PASS 1: windowsPE
       Runs inside WinPE before OS image is applied to disk.
       Handles: HW bypass, disk partitioning, driver injection, image selection.
       ================================================================= -->
  <settings pass="windowsPE">

    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">

      <!-- Bypass Windows 11 hardware requirements (TPM, SecureBoot, etc.) -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add HKLM\SYSTEM\Setup\LabConfig /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>

      <!-- UEFI/GPT disk layout: EFI (100MB) + MSR (16MB) + Windows (rest) -->
      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>2</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Size>100</Size>
              <Type>EFI</Type>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Size>16</Size>
              <Type>MSR</Type>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Extend>true</Extend>
              <Type>Primary</Type>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Format>FAT32</Format>
              <Label>System</Label>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Format>NTFS</Format>
              <Label>Windows</Label>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
        <WillShowUI>OnError</WillShowUI>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>Windows 11 Pro</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>2</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
        </OSImage>
      </ImageInstall>

      <UserData>
        <ProductKey>
          <Key>W269N-WFGWX-YVC9B-4J6C9-T83GX</Key>
        </ProductKey>
        <AcceptEula>true</AcceptEula>
      </UserData>
    </component>

    <!-- VirtIO driver injection: vioscsi + viostor + NetKVM for ARM64
         Drive letter varies with USB enumeration order, so cover D: E: F:
         Invalid paths are silently ignored -->
    <component name="Microsoft-Windows-PnpCustomizationsWinPE"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <DriverPaths>
        <PathAndCredentials wcm:action="add" wcm:keyValue="1">
          <Path>D:\vioscsi\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="2">
          <Path>D:\NetKVM\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="3">
          <Path>E:\vioscsi\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="4">
          <Path>E:\NetKVM\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="5">
          <Path>F:\vioscsi\w11\ARM64</Path>
        </PathAndCredentials>
        <PathAndCredentials wcm:action="add" wcm:keyValue="6">
          <Path>F:\NetKVM\w11\ARM64</Path>
        </PathAndCredentials>
      </DriverPaths>
    </component>
  </settings>

  <!-- =================================================================
       PASS 3: specialize
       Runs on first boot of installed OS. Machine-specific config.
       ================================================================= -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <ComputerName>WINVM</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>
  </settings>

  <!-- =================================================================
       PASS 7: oobeSystem
       Runs during Windows Welcome. User accounts, OOBE skip, first-run.
       ================================================================= -->
  <settings pass="oobeSystem">

    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <ProtectYourPC>3</ProtectYourPC>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>testuser</Name>
            <DisplayName>Test User</DisplayName>
            <Group>Administrators</Group>
            <Password>
              <Value>TestPass123!</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>testuser</Username>
        <Password>
          <Value>TestPass123!</Value>
          <PlainText>true</PlainText>
        </Password>
        <LogonCount>1</LogonCount>
      </AutoLogon>

      <FirstLogonCommands>
        <!-- 0. Start logging for post-mortem debugging -->
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "$log = 'C:\Windows\Temp\firstlogon.log'; '=== FirstLogonCommands starting ===' | Out-File -FilePath $log -Append -Encoding utf8; ('Timestamp: ' + (Get-Date -Format o)) | Out-File -FilePath $log -Append -Encoding utf8"</CommandLine>
          <Description>Start first-logon logging</Description>
        </SynchronousCommand>

        <!-- 1. Enable DHCP on the first up adapter so every overlay gets its own lease -->
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "$l='C:\Windows\Temp\firstlogon.log';$a=$null;1..24|%{if(!$a){$a=Get-NetAdapter|? Status -eq Up|sort ifIndex|select -First 1;if(!$a){sleep 5}}};if(!$a){Add-Content $l 'DHCP no adapter';exit 0};try{Get-NetIPAddress -InterfaceIndex $a.ifIndex -AddressFamily IPv4 -PrefixOrigin Manual -EA 0|Remove-NetIPAddress -Confirm:$false -EA 0;Get-NetRoute -InterfaceIndex $a.ifIndex -AddressFamily IPv4 -EA 0|? NextHop -ne '0.0.0.0'|Remove-NetRoute -Confirm:$false -EA 0;Set-NetIPInterface -InterfaceIndex $a.ifIndex -Dhcp Enabled -EA Stop;Set-DnsClientServerAddress -InterfaceIndex $a.ifIndex -ResetServerAddresses -EA Stop;ipconfig /renew | Out-Null;Add-Content $l 'DHCP OK'}catch{Add-Content $l ('DHCP FAIL ' + $_.Exception.Message)}"</CommandLine>
          <Description>Enable DHCP on primary adapter</Description>
        </SynchronousCommand>

        <!-- 2. Install and enable OpenSSH Server, retrying until the network is ready -->
        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "$l='C:\Windows\Temp\firstlogon.log';$ok=$false;1..20|%{if(!$ok){try{Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0 -EA Stop|Out-Null;sc.exe config sshd start= auto | Out-Null;Start-Service sshd -EA 0;netsh advfirewall firewall add rule name=OpenSSH-Server-In-TCP dir=in action=allow protocol=TCP localport=22 | Out-Null;$ok=$true}catch{sleep 15}}};if($ok){Add-Content $l 'OpenSSH OK'}else{Add-Content $l 'OpenSSH FAIL'}"</CommandLine>
          <Description>Install and enable OpenSSH Server</Description>
        </SynchronousCommand>

        <!-- 3. Install the host SSH public key for BatchMode verification -->
        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "$l='C:\Windows\Temp\firstlogon.log';$k='__HOST_SSH_PUBKEY__';$f='C:\ProgramData\ssh\administrators_authorized_keys';try{Set-Content $f $k;$acl=Get-Acl 'C:\ProgramData\ssh\sshd_config';Set-Acl $f $acl;Add-Content $l 'SSHKey OK'}catch{Add-Content $l 'SSHKey FAIL'}"</CommandLine>
          <Description>Install SSH authorized key</Description>
        </SynchronousCommand>

        <!-- 4. Download and install Tailscale (direct MSI, no winget dependency) -->
        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "$l='C:\Windows\Temp\firstlogon.log';$ok=$false;1..20|%{if(!$ok){try{Invoke-WebRequest https://pkgs.tailscale.com/stable/tailscale-setup-latest-arm64.msi -OutFile C:\Windows\Temp\tailscale.msi -EA Stop;$p=Start-Process msiexec.exe -ArgumentList '/i','C:\Windows\Temp\tailscale.msi','/quiet','/norestart' -Wait -PassThru;if($p.ExitCode -eq 0 -and (Test-Path 'C:\Program Files\Tailscale\Tailscale.exe')){$ok=$true}else{throw 'install'}}catch{sleep 15}}};if($ok){Add-Content $l 'Tailscale OK'}else{Add-Content $l 'Tailscale FAIL'}"</CommandLine>
          <Description>Download and install Tailscale</Description>
        </SynchronousCommand>

        <!-- 98. Stop transcript before shutdown -->
        <SynchronousCommand wcm:action="add">
          <Order>98</Order>
          <CommandLine>powershell -ExecutionPolicy Bypass -Command "$log = 'C:\Windows\Temp\firstlogon.log'; '=== FirstLogonCommands complete ===' | Out-File -FilePath $log -Append -Encoding utf8; ('Timestamp: ' + (Get-Date -Format o)) | Out-File -FilePath $log -Append -Encoding utf8"</CommandLine>
          <Description>Finish first-logon logging</Description>
        </SynchronousCommand>

        <!-- 99. Signal build complete by shutting down -->
        <SynchronousCommand wcm:action="add">
          <Order>99</Order>
          <CommandLine>shutdown /s /t 30 /c "Base image build complete"</CommandLine>
          <Description>Shut down after setup complete</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>

</unattend>
