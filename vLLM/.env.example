# =============================================================================
# vLLM Deployment Configuration — Qwen3-Coder-Next NVFP4 on GB10
# =============================================================================
#
# Calibrated profile for serving Qwen3-Coder-Next (79.7B MoE, NVFP4) on
# NVIDIA GB10 / GB200 (Blackwell, unified memory, ARM64).
#
# Quick start:
#   1. Copy this file to .env:           cp .env.example .env
#   2. Set your HuggingFace token below  (see HF_TOKEN)
#   3. Adjust host paths if needed       (see Paths section)
#   4. Start:                            uv run bootstrap-vllm up
#
# All other values are load-tested defaults from the Run 002 calibration
# series. Do not change them unless you know what you're doing.
# =============================================================================

# -----------------------------------------------------------------------------
# HuggingFace Authentication
# -----------------------------------------------------------------------------
# Required on first run to download the model (~43 GiB).
# The model is gated (auto-approved): visit the model page on HuggingFace,
# click "Accept", then paste your token here.
#   https://huggingface.co/saricles/Qwen3-Coder-Next-NVFP4-GB10
#   https://huggingface.co/settings/tokens
HF_TOKEN=

# -----------------------------------------------------------------------------
# Host Paths (machine-specific — adjust to match your system)
# -----------------------------------------------------------------------------
# These are bind-mounted into the container. The model cache must have ~50 GiB
# of free space for the initial download.
VLLM_MODEL_CACHE=/opt/dev/models/cache/huggingface
VLLM_HOST_DEV=/opt/dev
VLLM_HOST_BIN=/usr/local/bin
VLLM_HOST_HOME=/home/steve

# =============================================================================
# CALIBRATED DEFAULTS — do not change below this line
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
# Qwen3-Coder-Next 79.7B MoE (hybrid DeltaNet + attention, 10 active of 512
# experts, 3B active params/token). NVFP4-quantized via llm-compressor,
# stored as compressed-tensors. Requires Blackwell (SM 12.x) FP4 tensor cores.
VLLM_MODEL=saricles/Qwen3-Coder-Next-NVFP4-GB10

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
# 48K effective context (49152 tokens). Calibrated ceiling for 4 concurrent
# sessions on 128 GiB unified memory with gpu_memory_utilization=0.46.
VLLM_MAX_MODEL_LEN=49152

# -----------------------------------------------------------------------------
# GPU / Memory
# -----------------------------------------------------------------------------
# 0.46 utilization is the calibrated safe ceiling for GB10 128 GiB unified
# memory. Peak steady-state lands at ~75 GiB with ~13 GiB headroom.
# Be careful when changing this value — the operating system may not have
# guardrails to protect against running out of memory.
VLLM_GPU_MEMORY_UTILIZATION=0.46
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_ENFORCE_EAGER=true

# -----------------------------------------------------------------------------
# Quantization — NVFP4 Marlin backend (all four are required as a set)
# -----------------------------------------------------------------------------
# These are official vLLM environment variables (defined in vllm/envs.py)
# that configure the NVFP4-on-Marlin codepath for Blackwell GPUs.
VLLM_QUANTIZATION=compressed-tensors
#
# Selects Marlin as the GEMM backend for NVFP4 weight dequantization.
# Alternatives: flashinfer-cudnn, cutlass. Marlin is validated on GB10.
VLLM_NVFP4_GEMM_BACKEND=marlin
#
# Forces FP8 Marlin kernels. Required for the NVFP4→Marlin path on GB10.
# (The TEST_ prefix is upstream naming — this is stable and required.)
VLLM_TEST_FORCE_FP8_MARLIN=1
#
# Disables FlashInfer MoE FP4 path so Marlin handles all FP4 GEMM ops.
# Default is already 0; set explicitly to prevent upstream default changes.
VLLM_USE_FLASHINFER_MOE_FP4=0
#
# Enables atomicAdd in Marlin kernel, reducing barrier overhead for small n.
# Measurable throughput improvement on GB10.
VLLM_MARLIN_USE_ATOMIC_ADD=1

# -----------------------------------------------------------------------------
# vLLM Engine Flags
# -----------------------------------------------------------------------------
# These are appended to `vllm serve` as CLI arguments.
#   --kv-cache-dtype fp8           FP8 KV cache (halves KV memory vs FP16)
#   --attention-backend flashinfer FlashInfer attention (required for FP8 KV)
#   --enable-prefix-caching        Reuse KV blocks across shared prefixes
#   --enable-chunked-prefill       Overlap prefill and decode for throughput
#   --max-num-batched-tokens 8192  Chunked-prefill budget per iteration
#   --max-num-seqs 4               Max concurrent sequences (4 sessions)
#   --enable-auto-tool-choice      Enable tool/function calling
#   --tool-call-parser qwen3_coder Parser for Qwen3-Coder tool call format
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --attention-backend flashinfer --enable-prefix-caching --enable-chunked-prefill --max-num-batched-tokens 8192 --max-num-seqs 4 --enable-auto-tool-choice --tool-call-parser qwen3_coder

# -----------------------------------------------------------------------------
# Docker Image
# -----------------------------------------------------------------------------
# Custom image with NVFP4 Marlin kernels for Blackwell. Based on vLLM
# 0.16.0rc2 with CUDA 13.0 and SM 12.1 support. ARM64 only.
VLLM_IMAGE=avarok/dgx-vllm-nvfp4-kernel:v23
