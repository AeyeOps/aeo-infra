# Model Configuration
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ

# Server Configuration
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_MAX_MODEL_LEN=32768

# GPU Configuration
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_ENFORCE_EAGER=true

# Quantization (leave empty for vLLM auto-detection from config.json)
VLLM_QUANTIZATION=
# NVFP4 GEMM backend: marlin | flashinfer-cudnn | "" (unset). NVFP4 models only.
VLLM_NVFP4_GEMM_BACKEND=
# Additional NVFP4 env vars for GB10 Marlin path (leave empty for non-NVFP4 models)
VLLM_TEST_FORCE_FP8_MARLIN=
VLLM_USE_FLASHINFER_MOE_FP4=
VLLM_MARLIN_USE_ATOMIC_ADD=
# Free-form extra args appended to 'vllm serve' (space-separated tokens)
VLLM_EXTRA_ARGS=

# Paths
VLLM_MODEL_CACHE=/opt/dev/models/cache/huggingface
VLLM_HOST_DEV=/opt/dev
VLLM_HOST_BIN=/usr/local/bin
VLLM_HOST_HOME=/home/YOUR_USER
HF_TOKEN=

# Docker
VLLM_IMAGE=nvcr.io/nvidia/vllm:25.12-py3
